# Absolute HTTPS destination for the existing SlfStrg sign-in experience.
NEXT_PUBLIC_APP_URL=

# Resend API credentials used by /api/demo-request on Vercel.
RESEND_API_KEY=

# Inbox that receives demo requests.
DEMO_REQUEST_TO_EMAIL=

# Verified Resend sender, for example: SlfStrg Demo <demo@your-domain.com>
DEMO_REQUEST_FROM_EMAIL=
